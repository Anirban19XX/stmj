# ============================================================================
# Aegis frontend environment — copy to web/.env.local and fill in the blanks.
#
# Every variable is prefixed NEXT_PUBLIC_ and is therefore exposed to the
# browser bundle. Do NOT put secrets here — these are public, client-side values.
# Defaults below target Stellar TESTNET.
# ============================================================================

# Which network the app talks to: testnet | local | mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC endpoint used for simulating/submitting contract invocations.
#   testnet: https://soroban-testnet.stellar.org
#   local:   http://localhost:8000/soroban/rpc
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — MUST match the target network exactly.
#   testnet: "Test SDF Network ; September 2015"
#   local:   "Standalone Network ; February 2017"
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Horizon endpoint (classic Stellar data: accounts, balances, history).
#   testnet: https://horizon-testnet.stellar.org
#   local:   http://localhost:8000
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployed contract ids — fill in from deployments/<network>.json after deploy.
# (See scripts/deploy_testnet.sh, which prints these for you.)
NEXT_PUBLIC_ESCROW_CONTRACT_ID=
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=

# Default settlement token = the native XLM Stellar Asset Contract (SAC).
# Get the testnet native SAC id with:
#   stellar contract id asset --asset native --network testnet
NEXT_PUBLIC_DEFAULT_TOKEN_ID=

# Block explorer base URL used to build links to tx/contract pages.
#   testnet: https://stellar.expert/explorer/testnet
#   mainnet: https://stellar.expert/explorer/public
NEXT_PUBLIC_EXPLORER_BASE_URL=https://stellar.expert/explorer/testnet
